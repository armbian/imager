{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Armbian Imager",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    "store:default",
    "fs:default",
    "fs:allow-write-text-file",
    "dialog:allow-save"
  ]
}
